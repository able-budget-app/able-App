{
  "name": "able-ios-wrapper",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor iOS shell for Able. Bundles ../app.html + assets into www/, then wraps as a native iOS app.",
  "scripts": {
    "sync:www": "node scripts/sync-www.mjs",
    "cap:sync": "npm run sync:www && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:doctor": "npx cap doctor"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/share": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4"
  }
}
