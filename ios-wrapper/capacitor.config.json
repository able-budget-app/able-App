{
  "appId": "com.becomeable.app",
  "appName": "Able",
  "webDir": "www",
  "ios": {
    "contentInset": "never",
    "scheme": "Able",
    "backgroundColor": "#2a7a4a",
    "limitsNavigationsToAppBoundDomains": false
  },
  "server": {
    "iosScheme": "able"
  },
  "plugins": {
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": true,
      "style": "default"
    },
    "SplashScreen": {
      "launchShowDuration": 5000,
      "launchAutoHide": false,
      "backgroundColor": "#2a7a4a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
