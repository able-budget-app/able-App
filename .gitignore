# Local env files (service role keys, etc — never commit)
.env
.env.local
.env.*.local

# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp
*~

# Logs
*.log

# Supabase CLI local cache
supabase/.temp/
supabase/.branches/

# Social export — derived artifacts (PNG/MP4) are heavy and re-buildable
# via scripts/export-social.py. Keep _master-sheet.csv (source-of-truth schedule).
marketing-footage/social-export/_raw/
marketing-footage/social-export/singles/
marketing-footage/social-export/carousels/
marketing-footage/social-export/reels/

# Marketing footage — raw assets and rendered MP4s are heavy and re-buildable
# via scripts/record-clips.py / render-* scripts. Keep manifest.json.
marketing-footage/_raw/
marketing-footage/lifestyle-base/
marketing-footage/*.mp4
# product-shots is mostly heavy regenerable PNGs, but the HTML composer
# templates (_frame.html, _lifestyle.html, _bank-connect.html) are source
# code for the renderers and must stay on origin.
marketing-footage/product-shots/*
!marketing-footage/product-shots/_*.html
# Same pattern for the illustrations subdir (Plaid handshake etc.) —
# track the HTML composer templates, ignore the rendered PNG output.
marketing-footage/illustrations/*
!marketing-footage/illustrations/_*.html

# Cinematic Remotion sub-project (~660MB, separate workflow)
able-reel/

# Generated PDFs at repo root — regenerable from docs/*.md via the
# headless-Chrome script in /tmp/make_policy_pdfs.py
/*.pdf

# Captured app/landing screen images — regenerable via
# scripts/capture-design-screens.py and scripts/capture-product-shots.py
docs/design-screens/

# Skill packaging zips — built from ~/.claude/skills/. Keep SKILL.md.
able-skills-upload/*.zip

# Per-user Claude Code state (settings, session locks)
.claude/

# Competitor screenshot dump (one-off audit input; not part of the app)
Other App Screenshots /

# Icon animation experiment — source PNG, render script, and rendered
# outputs. One-off; not used by the app or build.
/icon-1024.png
/icon-animation.html
/icon-animation.gif
/icon-animation.mp4
/scripts/render-icon-animation.py

# OAuth tokens / API credentials — never commit
secrets/

# AI council reports + research experiments (research outputs, not source)
council/
experiments/

# Article-video working folders (audio renders, screenshots, intermediate output)
# Regenerable via article-video/scripts/* — heavy artifacts shouldn't be tracked.
article-video/videos/

# Legal/policy PDFs moved out of repo root — keep untracked.
# Regenerable from docs/*.md via the headless-Chrome script.
/docs/legal/*.pdf
