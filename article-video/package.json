{
  "name": "able-article-video",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion-based pipeline that turns an Able article into a 3-4 min YouTube video with OpenAI TTS narration and brand-correct visuals.",
  "scripts": {
    "new": "tsx scripts/new-video.ts",
    "draft": "tsx scripts/draft-script.ts",
    "draft-all": "tsx scripts/draft-all.ts",
    "chapters": "tsx scripts/chapter-list.ts",
    "tts": "tsx scripts/generate-audio.ts",
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts ArticleVideo videos/$VIDEO/out.mp4 --props=videos/$VIDEO/script.json --timeout=120000",
    "thumbnail": "remotion still src/index.ts Thumbnail videos/$VIDEO/thumbnail.png --props=videos/$VIDEO/script.json --log=warn",
    "build": "npm run tts && npm run thumbnail && npm run render",
    "all": "tsx scripts/build-all.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@remotion/bundler": "^4.0.250",
    "@remotion/cli": "^4.0.250",
    "@remotion/renderer": "^4.0.250",
    "openai": "^4.73.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.250",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
